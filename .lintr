linters: linters_with_defaults(
    line_length_linter = line_length_linter(120L),
    object_usage_linter = NULL,
    object_length_linter = object_length_linter(45L),
    object_name_linter = NULL,
    return_linter = NULL,
    trailing_whitespace_linter = NULL
  )
exclusions: list(
  "inst")
encoding: "UTF-8"
